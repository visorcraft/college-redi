{
  "name": "redi",
  "version": "0.1.14",
  "private": true,
  "license": "GPL-3.0-only",
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "DATA_DIR=\"${DATA_DIR:-./data}\" sh scripts/bootstrap-env.sh && next dev",
    "build": "next build --webpack",
    "start": "sh scripts/start-production.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run -c vitest.integration.config.ts tests/integration",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@visorcraft/mongreldb": "0.60.3",
    "@visorcraft/mongreldb-kit": "0.60.3",
    "apache-arrow": "21.1.0",
    "argon2": "0.44.0",
    "imapflow": "1.4.7",
    "mailparser": "3.9.14",
    "next": "16.2.10",
    "node-cron": "4.6.0",
    "nodemailer": "9.0.3",
    "openai": "6.48.0",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "twilio": "6.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/mailparser": "3.4.6",
    "@types/node": "24.13.3",
    "@types/node-cron": "3.0.11",
    "@types/nodemailer": "8.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "pdf-lib": "1.17.1",
    "postcss": "8.5.19",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "allowScripts": {
    "argon2@0.44.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
