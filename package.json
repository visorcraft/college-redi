{
  "name": "redi",
  "version": "0.1.5",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "DATA_DIR=\"${DATA_DIR:-./data}\" sh scripts/bootstrap-env.sh && next dev",
    "build": "next build",
    "start": "DATA_DIR=\"${DATA_DIR:-./data}\" sh scripts/bootstrap-env.sh && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run -c vitest.integration.config.ts tests/integration",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@visorcraft/mongreldb": "0.59.0",
    "@visorcraft/mongreldb-kit": "0.59.0",
    "apache-arrow": "^21.1.0",
    "argon2": "^0.43.0",
    "dotenv": "^16.4.5",
    "imapflow": "^1.0.164",
    "mailparser": "^3.9.14",
    "next": "^15.5.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.0",
    "openai": "^5.0.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twilio": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.54.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.0",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
